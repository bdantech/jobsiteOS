# Only PUBLIC values belong here. The Supabase service role key and the
# Anthropic/Resend keys are server-side concerns and live in apps/web only —
# the mobile app reaches them indirectly through the Next.js API (/api/*).

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon key>

# Base URL of the Next.js app, which acts as the mobile backend.
# Dev on a physical device: use your machine's LAN IP (e.g. http://192.168.0.10:3000).
# localhost will NOT resolve from the device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── EAS ─────────────────────────────────────────────────────────────────────
# From `eas init` — also lands in app.json under expo.extra.eas.projectId.
# Required for Expo push notifications to be delivered.
EAS_PROJECT_ID=<eas project id>
