# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key — safe to expose to the browser>

# SERVER ONLY. Bypasses RLS entirely. Never import into a client component,
# never expose via NEXT_PUBLIC_*, never copy into apps/mobile.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
# Powers the AI Bar (/api/ai). Model: claude-sonnet-4-6.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Sends temp passwords on admin user creation, and digests.
# Create at https://resend.com/api-keys. Verify your sending domain first.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="JobsiteOS <no-reply@yourdomain.com>"

# ─── Seed ────────────────────────────────────────────────────────────────────
# Email of the first admin user created by `pnpm seed`.
SEED_ADMIN_EMAIL=admin@yourdomain.com

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# The public key must be exposed to the browser to subscribe the service worker.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid public key>
VAPID_PUBLIC_KEY=<same value as above>
VAPID_PRIVATE_KEY=<vapid private key — server only>
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for Vercel Cron → /api/cron/*. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=<random 64-char hex>

# ─── Mercado worker (apps/worker, deployed on Railway) ───────────────────────
# The web app NEVER ingests Receita/CNO data itself (multi-GB dumps). It only
# triggers the worker: monthly via Vercel Cron (/api/cron/mercado-receita,
# /api/cron/mercado-cno) and on demand from the Ingestões admin page.
#
# WORKER_URL   — base URL of the worker service, no trailing path.
#                Its endpoints are POST /jobs/receita and POST /jobs/cno.
# WORKER_SECRET— bearer token the worker requires on those endpoints. Must be the
#                SAME value configured as WORKER_SECRET on the worker service.
#
# SERVER ONLY, both of them. Never NEXT_PUBLIC_*, never imported by a client
# component: they are read exclusively in src/lib/mercado/worker.ts.
WORKER_URL=https://jobsiteos-worker.up.railway.app
WORKER_SECRET=<random 64-char hex — same value on the worker>
