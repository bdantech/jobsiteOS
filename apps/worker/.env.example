# ─────────────────────────────────────────────────────────────────────────────
# @jobsiteos/worker — copie para .env e preencha. NUNCA versione o .env.
# ─────────────────────────────────────────────────────────────────────────────

# Bearer exigido em TODA rota. Gere com: openssl rand -base64 48
# O mesmo valor precisa estar no Vercel (o cron mensal manda esse header).
WORKER_SECRET=

# Postgres DIRETO (porta 5432), NÃO o pooler de transações (6543).
# O worker usa COPY e tabelas TEMP — as duas coisas são estado de sessão, e o
# pooler de transações devolve a conexão a cada statement. Com o pooler, o COPY
# funciona e a tabela TEMP some no statement seguinte.
# postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=

# Cliente service-role (PostgREST): mercado_ingestoes, eventos e notify().
# A service role ignora RLS. Este valor nunca sai do servidor.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Fontes ──────────────────────────────────────────────────────────────────
# A Receita é SEMPRE a fonte primária. O espelho só entra por decisão humana,
# em "Reexecutar com fallback" na tela de Ingestões — nunca automaticamente.
# A Receita migrou para um share público do Nextcloud. Base do WebDAV; os arquivos
# baixam de {BASE}/{mes}/{arquivo}. O caminho antigo (/dados/cnpj/...) dá 404.
RECEITA_BASE_URL=https://arquivos.receitafederal.gov.br/public.php/webdav
# Token do share público, usado como usuário do Basic-auth (senha vazia).
RECEITA_SHARE_TOKEN=YggdBLfdninEJX9
RECEITA_FALLBACK_URL=https://dados-abertos-rf-cnpj.casadosdados.com.br
# Pasta do mês (YYYY-MM). Em branco = mês corrente.
RECEITA_MES=
# Em quantas partes zipadas cada arquivo grande vem (Empresas0..9, etc).
RECEITA_PARTES=10

CNO_SOURCE_URL=https://arquivos.receitafederal.gov.br/dados/cno/cno.zip

# ─── Execução ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# Cache dos downloads. No Railway, monte um volume aqui: sem volume, um restart
# na terceira hora do download recomeça do zero.
DOWNLOAD_DIR=/data/receita

# Retentativas por arquivo, com backoff exponencial espalhado por HORAS
# (15min → 45min → 2h15 → 6h45). O servidor da Receita é lento, não instável:
# repetir de 5 em 5 segundos queima as 5 tentativas em um minuto.
RETRY_TENTATIVAS=5
RETRY_BASE_MS=900000
RETRY_FATOR=3

# NÃO existe variável de limiar de promoção aqui, de propósito. Ele vive na
# tabela app_config (migration 0016, chave 'mercado.promocao_camada'), é escrito
# pela tela da Pirâmide e lido pelo worker direto do banco. Como env var, a
# configuração tinha dois donos: um admin que escolhesse 'somente manual' na UI
# veria a próxima ingestão promover assim mesmo, no valor que estivesse aqui.

# ─── Notificações (notify(), em packages/core/src/server) ────────────────────
# Sem estas, o alerta de ingestão falhou ainda grava a notificação no sino —
# só não faz o push web. Os mesmos valores do apps/web.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@oneos.com.br
